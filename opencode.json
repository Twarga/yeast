{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AI-RULES.md"
  ],
  "model": "openai/gpt-5.5",
  "small_model": "opencode/deepseek-v4-flash-free",
  "default_agent": "planner",
  "agent": {
    "planner": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "description": "Primary orchestrator for Yeast. Plans work, assigns exact file ownership, reviews outputs, integrates results, and may make small unblock or cleanup edits when needed.",
      "temperature": 0.2,
      "maxSteps": 8,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow"
      }
    },
    "executor1": {
      "mode": "primary",
      "model": "opencode/minimax-m2.5-free",
      "description": "Main implementation worker for bounded coding tasks in Yeast. Follow planner instructions, stay inside assigned files, and do not expand scope.",
      "temperature": 0.3,
      "maxSteps": 12,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow"
      }
    },
    "executor2": {
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free",
      "description": "Parallel worker for disjoint-scope tasks only. Use for separate files like tests, docs, or isolated modules. Do not edit files owned by executor1.",
      "temperature": 0.3,
      "maxSteps": 10,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow"
      }
    },
    "title": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "summary": {
      "model": "opencode/deepseek-v4-flash-free"
    }
  }
}
